{
  "name": "@shuffle/root",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "catalogs": {
    "shared": {
      "@hono/zod-openapi": "^1.3.0",
      "drizzle-orm": "^0.36.4",
      "date-fns": "^4.1.0",
      "zod": "^4.3.6"
    }
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "oxlint": "^1.49.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:backend": "bun --elide-lines 0 --env-file=.env --filter @shuffle:backend dev",
    "db:generate": "bun --elide-lines 0 --env-file=.env --filter @shuffle:shared db:generate",
    "db:migrate": "bun --elide-lines 0 --env-file=.env --filter @shuffle:shared db:migrate",
    "db:push": "bun --elide-lines 0 --env-file=.env --filter @shuffle:shared db:push",
    "db:studio": "bun --elide-lines 0 --env-file=.env --filter @shuffle:shared db:studio",
    "db:migrate:deploy": "bun --elide-lines 0 --env-file=.env --filter @shuffle:shared db:migrate:deploy",
    "db:create:new": "bun --elide-lines 0 --env-file=.env --filter @shuffle:shared db:start",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  }
}
